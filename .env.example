# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-very-long-random-secret-key

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///liyu_kids.db
# DATABASE_URL=postgresql://user:password@localhost:5432/liyu_kids

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key

# Grok AI
GROK_API_KEY=your-grok-api-key-here

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=Liyu_Kids_Mart_Bot
TELEGRAM_MEDIA_CHAT_ID=-1001234567890
TELEGRAM_MAIN_CHANNEL_ID=@your-main-channel
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook
# Optional: short name from BotFather /newapp (enables https://t.me/bot/appname links)
TELEGRAM_MINI_APP_SHORT_NAME=

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Upload
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216

# App
APP_URL=https://liyu-kids-mart.vercel.app
MINI_APP_URL=https://liyu-kids-mart.vercel.app/telegram/mini-app
